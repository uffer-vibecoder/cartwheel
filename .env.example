# Copy to ".env" and fill in to enable real cross-device accounts.
# Without these, whim runs in local-account mode (browser-only profiles).

# Supabase → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google AdSense (optional) → publisher id + an ad unit slot id.
# Leave blank to keep the in-house "house ad". NOTE: AdSense approval requires a
# domain you own — a github.io subpath will not be approved.
VITE_ADSENSE_PUBLISHER=
VITE_ADSENSE_SLOT=
